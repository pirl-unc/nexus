process {
    standard {
        process.executor = 'slurm'
        process.queue = 'allnodes'
        executor.queueSize = '95'
        executor.submitRateLimit = '10s'
        singularity.enabled = true
        singularity.cacheDir = "$PWD"
        nodes = 1
	}
}

process {
    withLabel: 'abra2' {
        cpus = 64
        memory = '256.GB'
        time = '7days'
        java_max_mem = 256.GB
    }
